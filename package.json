{
  "name": "eng-learn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && node scripts/build-release-isolated.mjs",
    "build:release": "pnpm build",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && vue-tsc --noEmit -p tsconfig.component.json && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "test": "pnpm test:unit && pnpm test:component",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:component:watch": "vitest --config vitest.component.config.ts",
    "test:e2e": "pnpm test:e2e:ui && pnpm test:e2e:stack",
    "test:e2e:ui": "playwright test --config playwright.ui.config.ts",
    "test:e2e:stack": "node scripts/run-stack-e2e.mjs",
    "scan:artifacts": "node scripts/check-no-secret-artifacts.mjs",
    "cf:check": "node scripts/check-cloudflare-isolated.mjs check startup",
    "cf:types:check": "node scripts/check-cloudflare-isolated.mjs types --check",
    "cf:types": "node scripts/generate-cloudflare-types-isolated.mjs",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "admin:prepare:local": "pnpm db:migrate:local && node scripts/admin-init.mjs prepare-local",
    "admin:setup:local": "pnpm admin:prepare:local && pnpm admin:init:local",
    "admin:init:local": "node scripts/admin-init.mjs local",
    "admin:init:remote": "node scripts/admin-init.mjs remote",
    "admin:benchmark:local": "node scripts/benchmark-admin-credential.mjs",
    "dev:admin:local": "pnpm build && pnpm db:migrate:local && wrangler dev --local --ip 127.0.0.1 --port 8787 --local-protocol https"
  },
  "dependencies": {
    "@lucide/vue": "1.24.0",
    "jose": "^6.2.3",
    "papaparse": "5.5.4",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vite-plugin": "1.43.0",
    "@cloudflare/workers-types": "5.20260711.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "@types/papaparse": "5.5.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.6.0",
    "eslint-plugin-vue": "10.9.2",
    "happy-dom": "20.10.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.6",
    "wrangler": "4.110.0"
  },
  "packageManager": "pnpm@11.7.0"
}
